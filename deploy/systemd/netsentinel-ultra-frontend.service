[Unit]
Description=Netsentinel Ultra Core Frontend
After=network.target

[Service]
User=%i
WorkingDirectory=/home/%i/Netsentinel-ultra-core/frontend
ExecStart=/usr/bin/npm run start
Environment=NODE_ENV=production
Environment=PORT=3001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
